# Enable sendfile for faster local file serving
<IfModule mod_sendfile.c>
    SendFile on
</IfModule>

# Increase timeouts for large local transfers
<IfModule mod_core.c>
    KeepAliveTimeout 30
    Timeout 300
</IfModule>

# Ensure proper MIME types for video formats
<IfModule mod_mime.c>
    AddType video/mp4 .mp4 .m4v
    AddType video/webm .webm
    AddType video/ogg .ogv
    AddType video/x-matroska .mkv
</IfModule>

# Add browser caching controls for media files
<IfModule mod_headers.c>
    <FilesMatch "\.(mp4|m4v|webm|mkv|ogv)$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>
</IfModule>

# DLNA compliance headers for MP4 files (enables seamless casting to legacy TVs)
<IfModule mod_headers.c>
    <FilesMatch "\.mp4$">
        Header set contentFeatures.dlna.org "DLNA.ORG_PN=AVC_MP4_HP_HD_24p;DLNA.ORG_OP=01;DLNA.ORG_CI=0;DLNA.ORG_FLAGS=01700000000000000000000000000000"
        Header set transferMode.dlna.org "Streaming"
        Header set realTimeInfo.dlna.org "DLNA.ORG_LXT=0"
    </FilesMatch>
</IfModule>

# Disable content negotiation for video files
<IfModule mod_negotiation.c>
    Options -MultiViews
</IfModule>
