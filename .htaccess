<IfModule mod_mime.c>
    AddType video/mp4 .mp4 .m4v
    AddType video/webm .webm
    AddType video/ogg .ogv
    AddType video/x-matroska .mkv
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(mp4|m4v|webm|mkv|ogv)$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>

    <FilesMatch "\.mp4$">
        Header set Content-Type "video/mp4"
        Header set contentFeatures.dlna.org "DLNA.ORG_PN=AVC_MP4_BL_L31_HD_AAC;DLNA.ORG_OP=11;DLNA.ORG_CI=0;DLNA.ORG_FLAGS=01700000000000000000000000000000"
        Header set transferMode.dlna.org "Streaming"
        Header set realTimeInfo.dlna.org "DLNA.ORG_TLAG=*"
        Header set Accept-Ranges "bytes"
        Header set Connection "close"
    </FilesMatch>
</IfModule>

<IfModule mod_negotiation.c>
    Options -MultiViews
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. Route API calls to backend/
    RewriteRule ^api/(.*)$ backend/$1 [L,QSA]

    # 2. Rewrite root path accesses directly to the public folder
    RewriteRule ^$ public/ [L]

    # 3. Serve physical files if they exist in the root
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # 4. Serve physical directories if they exist in the root (e.g. thumbnails/, uploads/)
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 5. Otherwise, rewrite transparently to the public/ folder
    RewriteCond %{REQUEST_URI} !^/backend/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
